<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/navigation"
    app:startDestination="@id/titleFragment">
    <fragment
        android:id="@+id/titleFragment"
        android:name="com.example.pokepals.TitleFragment"
        android:label="PokePals – First Steps"
        tools:layout="@layout/fragment_title" >
        <action
            android:id="@+id/action_titleFragment_to_browseFragment"
            app:destination="@id/browseFragment" />
        <action
            android:id="@+id/action_titleFragment_to_trainerFragment"
            app:destination="@id/trainerFragment" />
        <action
            android:id="@+id/action_titleFragment_to_aboutFragment"
            app:destination="@id/aboutFragment" />
    </fragment>
    <fragment
        android:id="@+id/browseFragment"
        android:name="com.example.pokepals.BrowseFragment"
        android:label="PokePals – Your Pokemons"
        tools:layout="@layout/fragment_browse" />
    <fragment
        android:id="@+id/trainerFragment"
        android:name="com.example.pokepals.TrainerFragment"
        android:label="PokePals – Trainer Settings"
        tools:layout="@layout/fragment_trainer" />
    <fragment
        android:id="@+id/aboutFragment"
        android:name="com.example.pokepals.AboutFragment"
        android:label="PokePals – About The App"
        tools:layout="@layout/fragment_about" />
</navigation>